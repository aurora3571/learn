{
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/streamlit_app.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/",
      "dest": "frontend/streamlit_app.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/streamlit_app.py"
    }
  ]
}